---
interface Props {
  heading: string;
  sub: string;
  btnText?: string;
}
const { heading, sub, btnText = 'Agendá una call →' } = Astro.props;
---

<section class="cta-final" id="agenda">
  <div class="wrap">
    <div class="cta-box">
      <h2>{heading}</h2>
      <p>{sub}</p>
      <button type="button" data-cal-namespace="30min" data-cal-link="joaquin-syncrotap/30min" data-cal-config='{"layout":"month_view"}' class="btn btn-primary">{btnText}</button>
    </div>
  </div>
</section>
