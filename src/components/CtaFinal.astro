---
interface Props {
  heading: string;
  sub: string;
  btnText?: string;
}
const { heading, sub, btnText = 'Agendá una call →' } = Astro.props;
---

<section class="cta-final" id="agenda">
  <div class="wrap">
    <div class="cta-box">
      <h2>{heading}</h2>
      <p>{sub}</p>
      <a href="#" onclick="Calendly.initPopupWidget({url:'https://calendly.com/molinazavaliaj/30min'});return false;" class="btn btn-primary">{btnText}</a>
    </div>
  </div>
</section>
