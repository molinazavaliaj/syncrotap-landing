---
const pathname = Astro.url.pathname;

const isNFCSoluciones = pathname.startsWith('/gift-cards') || pathname.startsWith('/socios-y-accesos');
const isNFCProductos = pathname.startsWith('/merch-inteligente') || pathname.startsWith('/recitales-interactivos');
const isSobreNosotros = pathname.startsWith('/sobre-nosotros');
---

<header>
  <div class="wrap nav">
    <a href="/" class="brand">SYNCROTAP</a>
    <button class="nav-toggle" aria-label="Abrir menú">&#9776;</button>
    <nav class="nav-links">
      <div class={`nav-item has-sub${isNFCSoluciones ? ' active' : ''}`}>
        <a href="#">Soluciones NFC <span class="caret">&#9660;</span></a>
        <div class="submenu">
          <a href="/gift-cards">Gift cards<span class="s-desc">Tarjetas de regalo con saldo digital</span></a>
          <a href="/socios-y-accesos">Socios y accesos<span class="s-desc">Credenciales NFC/RFID para clubes</span></a>
        </div>
      </div>
      <div class={`nav-item has-sub${isNFCProductos ? ' active' : ''}`}>
        <a href="#">Productos NFC <span class="caret">&#9660;</span></a>
        <div class="submenu">
          <a href="/merch-inteligente">Merch inteligente<span class="s-desc">Merchandising con capa digital</span></a>
          <a href="/recitales-interactivos">Recitales interactivos<span class="s-desc">Merch NFC que cobra vida en vivo</span></a>
        </div>
      </div>
      <div class={`nav-item${isSobreNosotros ? ' active' : ''}`}>
        <a href="/sobre-nosotros">Sobre nosotros</a>
      </div>
      <a href="#" onclick="Calendly.initPopupWidget({url:'https://calendly.com/molinazavaliaj/30min'});return false;" class="btn btn-primary">Agendá una call</a>
    </nav>
  </div>
</header>
