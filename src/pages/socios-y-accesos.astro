---
import Base from '../layouts/Base.astro';
import CtaFinal from '../components/CtaFinal.astro';
import { Image } from 'astro:assets';
import credencial from '../assets/socios/credencial.png';
import recepcion from '../assets/socios/recepcion.png';
import presentismo from '../assets/socios/presentismo.png';
import dashboard from '../assets/socios/dashboard.png';
---

<Base
  title="Socios y accesos — Syncrotap"
  description="Credenciales NFC/RFID para gestionar socios, accesos y cuotas en tiempo real. Control de acceso y dashboard gerencial llave en mano."
  ogTitle="Socios y accesos — Syncrotap"
  ogDescription="Tu club, bajo control con un tap. Credenciales NFC/RFID para socios, accesos y cuotas en tiempo real."
>

<!-- SUB HERO -->
<section class="subhero">
  <div class="wrap subhero-inner">
    <div class="crumb"><a href="/">Inicio</a> / Socios y accesos</div>
    <h1>Tu club, <span class="hl">bajo control</span> con un tap</h1>
    <p class="lead">Credenciales NFC/RFID para gestionar socios, accesos y cuotas en tiempo real.</p>
  </div>
</section>

<!-- PROBLEMA -->
<section class="block problem">
  <div class="wrap">
    <div class="problem-inner">
      <div class="bar"></div>
      <div>
        <h2>El problema</h2>
        <p>Listas en papel, cuotas impagas que nadie detecta y cero datos de asistencia. Todo eso desaparece con una credencial.</p>
      </div>
    </div>
  </div>
</section>

<!-- COMO FUNCIONA -->
<section class="block">
  <div class="wrap">
    <div class="sec-head">
      <span class="sec-tag">Cómo funciona</span>
      <h2>Del papel al tap</h2>
    </div>
    <div class="steps">
      <div class="step">
        <div class="n">1</div>
        <h3>Cada socio, su credencial</h3>
        <p>Cada socio recibe su credencial NFC/RFID personalizada.</p>
      </div>
      <div class="step">
        <div class="n">2</div>
        <h3>Tapea al ingresar</h3>
        <p>Marca presente y recepción ve al instante si está al día.</p>
      </div>
      <div class="step">
        <div class="n">3</div>
        <h3>Administrás desde el panel</h3>
        <p>Registrás pagos y consultás perfiles desde el dashboard.</p>
      </div>
    </div>
  </div>
</section>

<!-- DEMOS -->
<div class="demos-wrap">
  <section class="block">
    <div class="wrap">
      <div class="sec-head">
        <span class="sec-tag">Demos reales</span>
        <h2>Credenciales y paneles</h2>
        <p>Material de una implementación real: Área Chica.</p>
      </div>
      <div class="grid2">
        <figure>
          <Image src={credencial} alt="Credencial NFC personalizada" />
          <figcaption>Credencial NFC personalizada</figcaption>
        </figure>
        <figure>
          <Image src={recepcion} alt="Panel de recepción" />
          <figcaption>Panel de recepción</figcaption>
        </figure>
        <figure>
          <Image src={presentismo} alt="Control de presentismo" />
          <figcaption>Control de presentismo</figcaption>
        </figure>
        <figure>
          <Image src={dashboard} alt="Dashboard gerencial" />
          <figcaption>Dashboard gerencial</figcaption>
        </figure>
      </div>
    </div>
  </section>
</div>

<!-- QUE INCLUYE -->
<section class="block">
  <div class="wrap">
    <div class="sec-head">
      <span class="sec-tag">Qué incluye</span>
      <h2>Llave en mano</h2>
    </div>
    <div class="incluye">
      <div class="inc"><span class="chk">✓</span><span class="txt">Credenciales personalizadas</span></div>
      <div class="inc"><span class="chk">✓</span><span class="txt">Lectores</span></div>
      <div class="inc"><span class="chk">✓</span><span class="txt">Software de gestión</span></div>
      <div class="inc"><span class="chk">✓</span><span class="txt">Dashboard gerencial con métricas de asistencia y cobranza</span></div>
    </div>
  </div>
</section>

<CtaFinal
  heading="Modernizá la gestión de tu club"
  sub="Contanos tu caso en una call de 30 minutos. Salís con una propuesta concreta."
/>

</Base>
